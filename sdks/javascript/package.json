  },
  "keywords": [
    "promptsentinel",
    "llm",
    "prompt-injection",
    "security",
    "guardrails",
    "ai-safety"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gitsrc/PromptSentinel.git",
    "directory": "sdks/javascript"
  },
  "homepage": "https://github.com/gitsrc/PromptSentinel/tree/main/sdks/javascript#readme",
  "bugs": {
    "url": "https://github.com/gitsrc/PromptSentinel/issues"
  },
